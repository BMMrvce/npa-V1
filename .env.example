# NPA Management System - Environment Configuration Template

# ============================================================================
# SendGrid Email Configuration
# ============================================================================

# SendGrid API Key for sending emails
# Get this from: https://app.sendgrid.com/settings/api_keys
# Format: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Sender email address (must be verified in SendGrid)
# Options:
#   - noreply@npa.com (default, for testing)
#   - your-verified-domain@yourdomain.com (for production)
#   - support@yourdomain.com
SENDER_EMAIL=noreply@npa.com

# ============================================================================
# Supabase Configuration
# ============================================================================

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (for client-side auth)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (for server-side operations)
# Keep this secret! Never expose in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Application Configuration
# ============================================================================

# Application environment
NODE_ENV=development

# Application port
PORT=3000

# Application URL (for email links, etc)
APP_URL=http://localhost:5173

# Backend API URL
BACKEND_URL=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================

# Supabase uses PostgreSQL
# These are already configured in Supabase, no need to set here
# Database credentials are handled by SUPABASE_SERVICE_ROLE_KEY

# ============================================================================
# Optional: Advanced Email Configuration
# ============================================================================

# Email retry attempts (if email fails, retry this many times)
# EMAIL_MAX_RETRIES=3

# Email timeout in milliseconds
# EMAIL_TIMEOUT=10000

# Email batch size (if sending multiple emails)
# EMAIL_BATCH_SIZE=100

# ============================================================================
# Notes
# ============================================================================

# This is a template. Copy it to a new .env file and fill in your values:
# cp .env.example .env

# Never commit .env to version control!
# Add .env to .gitignore

# Ensure all required variables are set before running the application
